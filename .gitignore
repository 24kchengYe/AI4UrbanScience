# ============================================================
# AI4UrbanScience — gitignore
# ============================================================

# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# Experiment outputs — the full generated dataset is archived on Figshare;
# only a small `data/examples/` subset is committed to the repo so that
# reviewers can run the analysis scripts without an API key.
data/generated/
data/place_pulse/
data/real_world/
data/street_view/
data/perception_images/
# But DO commit the curated example replicates for quick reproduction:
!data/examples/
!data/examples/**

results/
*.log
logs/

# Large geospatial artifacts
*.tif
*.tiff
*.gdb/
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx
