# ============================================================
# AI4UrbanScience — environment-variable template
# Copy to .env and fill in your own keys. .env is gitignored.
# ============================================================

# ---- Text LLM APIs ----

# MindCraft (智匠 AI) aggregator — used for multi-model text experiments
MINDCRAFT_KEY=
MINDCRAFT_KEY_BACKUP=
MINDCRAFT_BASE_URL=https://api.mindcraft.com.cn/v1/chat/completions

# GPTsAPI — OpenAI-compatible proxy for GPT-4o and Claude
GPTSAPI_KEY=
GPTSAPI_BASE_URL=https://api.gptsapi.net/v1/chat/completions

# DeepSeek (official)
DEEPSEEK_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# ChatGLM / BigModel (智谱)
CHATGLM_KEY=
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# ---- Multimodal / image APIs ----

# Ablai — used for multimodal chat, image generation, image edit
ABLAI_KEY=
ABLAI_BASE_URL=https://api.ablai.top/v1

# ---- External geospatial datasets (Experiment 06 / 07) ----

# Absolute paths to the rasters / shapefiles. See data/README.md for sources.
REAL_DATA_CITY_BOUNDARY_PATH=
REAL_DATA_POP_RASTER_PATH=
REAL_DATA_GDP_RASTER_PATH=
REAL_DATA_ROAD_GDB_PATH=
REAL_DATA_BUILDING_BASE_PATH=
REAL_DATA_IMPERVIOUS_RASTER_PATH=
REAL_DATA_BLOCK_VECTOR_PATH=

# ---- Place Pulse 2.0 dataset (Experiment 04) ----
# Download from https://www.kaggle.com/datasets/ericpdavies/place-pulse-2-0
PLACE_PULSE_DIR=
